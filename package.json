{
  "name": "email-security-relay",
  "version": "1.0.0",
  "description": "Email Security Relay — SMTP security gateway that sits in front of any existing mail provider via MX record change (\"Cloudflare for Email\"). MVP implementation of the PRD roadmap.",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "build": "tsc && mkdir -p dist/dashboard && cp -r src/dashboard/. dist/dashboard/",
    "typecheck": "tsc --noEmit",
    "start": "node dist/main.js",
    "dev": "npm run build && node --watch dist/main.js",
    "test": "tsx --test test/*.test.ts",
    "test:send": "node scripts/test-send.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^6.5.0",
    "better-sqlite3": "^12.11.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mailparser": "^3.6.9",
    "nodemailer": "^6.9.13",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "smtp-server": "^3.13.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/smtp-server": "^3.5.13",
    "@types/supertest": "^7.2.1",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3"
  }
}
