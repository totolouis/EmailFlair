# Identity of this relay node — used in Received/X-Relay-ID headers and loop detection
RELAY_ID=relay-01
RELAY_SECRET=change-me-super-secret
RELAY_HOSTNAME=mx1.emailrelay.com

# Network
SMTP_PORT=2525
API_PORT=3000

# TLS / Let's Encrypt auto-provisioning for SMTP STARTTLS
# Enable this in production to get automated certs from Let's Encrypt.
# Traefik handles HTTPS API + SMTPS (port 465) certs separately via TLS-ALPN-01.
# The relay handles SMTP STARTTLS (port 25) using certs provisioned here.
TLS_ACME_ENABLED=false
TLS_ACME_EMAIL=admin@example.com
TLS_ACME_STORAGE=./data/acme
SMTP_TLS_PORT=465

# Security
SPAM_QUARANTINE_THRESHOLD=5
SPAM_REJECT_THRESHOLD=10

# Storage
DB_PATH=./data/relay.db
QUARANTINE_DIR=./data/quarantine

# A default tenant is seeded on first boot so the API is usable immediately.
DEFAULT_TENANT_NAME=Default Tenant
DEFAULT_TENANT_API_KEY=dev-tenant-key
